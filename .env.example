# Agent Factory — Environment Variables
# Copy to .env and fill in your values

# ── Mode flags ──────────────────────────────────────────────
# AGENT_FACTORY_DEV=1          # Use SQLite instead of PostgreSQL
# AGENT_FACTORY_MOCK=1         # Use mock AI provider (no API calls)

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentfactory

# ── DeepSeek API ────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ── JWT Auth ────────────────────────────────────────────────
# JWT_SECRET=your-secret-key-change-in-production

# ── CORS ────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
